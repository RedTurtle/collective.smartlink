<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:plone="http://namespaces.plone.org/plone"
    xmlns:zcml="http://namespaces.zope.org/zcml"
    i18n_domain="plone"
    >

  <!-- Transform order 8860 - apply theme transform -->
  <adapter
      factory=".transform.UidLinkTransform"
      name="collective.smartlink.transform"
      />

</configure>
